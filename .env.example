# ---- Server-side (set this in Vercel → Settings → Environment Variables) ----
# Never put this in a VITE_-prefixed variable — that would ship it to the
# browser. It's only read by the functions in /api, which run server-side.
ANTHROPIC_API_KEY=

# ---- Frontend (optional) ----
# Only needed if your AI backend lives somewhere other than this same
# Vercel project's /api folder. Leave blank to use /api by default.
VITE_AI_BACKEND_URL=
